}

<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="card shadow-sm border-0 p-4 about-card">
            <div class="row align-items-center">
                <div class="col-md-4 text-center mb-4 mb-md-0">
                    <img src="~/images/ahmed.jpg" alt="Ahmed Shaaban" class="about-profile-img img-fluid" />
                </div>

                <div class="col-md-8">
                    <h1 class="mb-2">Ahmed Shaaban</h1>
                    <p class="about-role mb-3">Software Engineer</p>

                    <p class="text-muted about-text">
                        I am Ahmed Shaaban, a Software Engineer passionate about building practical and useful digital products.
                        I enjoy developing web applications that solve real-world problems and improve people’s daily lives.
                    </p>

                    <p class="text-muted about-text">
                        "Qaryati" is one of the projects I created to help people easily find local services such as restaurants,
                        pharmacies, supermarkets, technicians, and other important services in their village or nearby areas.
                    </p>

                    <div class="mt-4">
                        <h4 class="mb-3">Contact Information</h4>

                        <div class="contact-box mb-3">
                            <strong>Phone 1:</strong>
                            <a href="tel:01112112568" class="text-decoration-none">01112112568</a>
                        </div>

                        <div class="contact-box mb-3">
                            <strong>Phone 2:</strong>
                            <a href="tel:01117979246" class="text-decoration-none">01117979246</a>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2 flex-wrap">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Back to Home</a>
                        <a href="tel:01112112568" class="btn btn-success">Call Me</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
