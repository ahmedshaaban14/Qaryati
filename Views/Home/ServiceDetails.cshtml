@model Qaryati.Models.Service

@{
    ViewData["Title"] = Model.Name;
    var firstLetter = !string.IsNullOrEmpty(Model.Name) ? Model.Name.Substring(0, 1) : "خ";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card shadow-sm border-0 overflow-hidden">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid w-100" style="max-height: 400px; object-fit: cover;" />
            }
            else
            {
                <div class="d-flex align-items-center justify-content-center" style="height: 280px; background: linear-gradient(135deg, #eaf7ee, #dff1e5);">
                    <div class="service-avatar" style="width: 90px; height: 90px; font-size: 2rem;">@firstLetter</div>
                </div>
            }

            <div class="card-body p-4">
                @if (Model.IsFeatured)
                {
                    <span class="badge bg-warning text-dark mb-3">خدمة مميزة</span>
                }

                <h1 class="mb-3">@Model.Name</h1>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <p><strong>القسم:</strong> @Model.Category?.Name</p>
                        <p><strong>رقم الهاتف:</strong> @Model.PhoneNumber</p>
                        <p><strong>رقم واتساب:</strong> @(string.IsNullOrEmpty(Model.WhatsAppNumber) ? "غير متوفر" : Model.WhatsAppNumber)</p>
                    </div>

                    <div class="col-md-6 mb-3">
                        <p><strong>العنوان:</strong> @(string.IsNullOrEmpty(Model.Address) ? "غير متوفر" : Model.Address)</p>
                        <p><strong>مواعيد العمل:</strong> @(string.IsNullOrEmpty(Model.WorkingHours) ? "غير محددة" : Model.WorkingHours)</p>
                    </div>
                </div>

                <hr />

                <h4 class="mb-3">وصف الخدمة</h4>
                <p class="text-muted">
                    @(string.IsNullOrEmpty(Model.Description) ? "لا يوجد وصف متاح لهذه الخدمة." : Model.Description)
                </p>

                <div class="mt-4 d-flex gap-2 flex-wrap">
                    <a href="tel:@Model.PhoneNumber" class="btn btn-success">
                        اتصال الآن
                    </a>

                    @if (!string.IsNullOrEmpty(Model.WhatsAppNumber))
                    {
                        <a href="https://wa.me/@Model.WhatsAppNumber" target="_blank" class="btn btn-outline-success">
                            تواصل واتساب
                        </a>
                    }

                    <a asp-action="CategoryServices" asp-route-id="@Model.CategoryId" class="btn btn-primary">
                        رجوع للقسم
                    </a>

                    <a asp-action="Index" class="btn btn-secondary">
                        الرئيسية
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>