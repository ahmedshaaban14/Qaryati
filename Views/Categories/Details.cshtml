@model Qaryati.Models.Category

@{
    ViewData["Title"] = "تفاصيل القسم";
}

<h1 class="mb-4">تفاصيل القسم</h1>

<div class="card">
    <div class="card-body">
        <h4 class="card-title">@Model.Name</h4>
        <p class="card-text">
            <strong>الوصف:</strong> @Model.Description
        </p>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">تعديل</a>
    <a asp-action="Index" class="btn btn-secondary">رجوع</a>
</div>