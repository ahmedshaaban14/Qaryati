@model Qaryati.Models.Category

@{
    ViewData["Title"] = "حذف قسم";
}

<h1 class="mb-4 text-danger">حذف القسم</h1>

<div class="alert alert-warning">
    هل أنت متأكد أنك تريد حذف هذا القسم؟
</div>

<div class="card">
    <div class="card-body">
        <h4>@Model.Name</h4>
        <p><strong>الوصف:</strong> @Model.Description</p>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">تأكيد الحذف</button>
    <a asp-action="Index" class="btn btn-secondary">إلغاء</a>
</form>