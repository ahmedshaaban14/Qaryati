@model Qaryati.Models.Service

@{
    ViewData["Title"] = "حذف خدمة";
}

<h1 class="mb-4 text-danger">حذف الخدمة</h1>

<div class="alert alert-warning">
    هل أنت متأكد أنك تريد حذف هذه الخدمة؟
</div>

<div class="card">
    <div class="card-body">
        <h4>@Model.Name</h4>
        <p><strong>رقم الهاتف:</strong> @Model.PhoneNumber</p>
        <p><strong>القسم:</strong> @Model.Category?.Name</p>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">تأكيد الحذف</button>
    <a asp-action="Index" class="btn btn-secondary">إلغاء</a>
</form>