@model Qaryati.Models.Service

@{
    ViewData["Title"] = "تفاصيل الخدمة";
}

<h1 class="mb-4">تفاصيل الخدمة</h1>

<div class="card">
    <div class="card-body">
        <h3>@Model.Name</h3>
        <p><strong>الوصف:</strong> @Model.Description</p>
        <p><strong>رقم الهاتف:</strong> @Model.PhoneNumber</p>
        <p><strong>رقم واتساب:</strong> @Model.WhatsAppNumber</p>
        <p><strong>العنوان:</strong> @Model.Address</p>
        <p><strong>مواعيد العمل:</strong> @Model.WorkingHours</p>
        <p><strong>القسم:</strong> @Model.Category?.Name</p>
        <p><strong>مميزة:</strong> @(Model.IsFeatured ? "نعم" : "لا")</p>

        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <div class="mt-3">
                <strong>الصورة:</strong><br />
                <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded mt-2" style="max-width: 300px;" />
            </div>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">تعديل</a>
    <a asp-action="Index" class="btn btn-secondary">رجوع</a>
</div>